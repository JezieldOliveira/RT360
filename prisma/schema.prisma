generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Simulation {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  regime      String
  receita     Float
  bestRegime  String
  lucro2033   Float
  margem2033  Float
  inputs      Json
  result      Json

  @@index([createdAt])
}
