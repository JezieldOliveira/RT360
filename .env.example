# String de conexão Postgres (Neon / Vercel Postgres).
# Sem esta variável o app funciona normalmente, apenas sem salvar o histórico de simulações.
# Exemplo (Neon, pooled): postgresql://user:senha@ep-xxx-pooler.sa-east-1.aws.neon.tech/rt360?sslmode=require
DATABASE_URL=

# Porta do servidor local (opcional)
PORT=3000
